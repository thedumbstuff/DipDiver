# Local env file — copy to .env.m2, fill keys, NEVER commit the copy.
# Scripts auto-load this from the repo root; no shell source needed.

# --- M2 (LLM factor proposer) ---
# At least one must be set for m2-lite. DEEPSEEK is the default --provider.
DEEPSEEK_API_KEY=sk-REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME

# --- M3 step 6 (Alpaca paper trading) ---
# Free signup: https://app.alpaca.markets/signup
# Then go to https://app.alpaca.markets/paper/dashboard/overview ,
# scroll to "Your API Keys", generate a paper key + secret.
ALPACA_API_KEY=PK_REPLACE_ME
ALPACA_API_SECRET=REPLACE_ME
