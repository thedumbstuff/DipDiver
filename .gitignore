# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
.python-version

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Type checkers / linters / test caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/

# Secrets — never commit
.env
.env.*
!.env.example
!.env.m2.example
secrets/
*.key
*.pem
credentials*.json

# M2-lite artefacts
logs/m2_lite/

# M3 signal CSVs and Lean projects (signals are large; Lean dirs get
# regenerated by `lean create-project` / `lean backtest`)
data/signals/
lean_projects/*/backtests/
lean_projects/*/data/

# Local data / model caches — never commit
data/
.qlib/
qlib_data/
mlruns/
*.parquet
*.feather
*.h5
*.pkl
*.pickle
*.joblib

# Lean artefacts — anchored to repo root so this does NOT also ignore the
# Python package dipdiver/adapters/lean/ (an unanchored `Lean/` matched it on
# case-insensitive filesystems, so those source files were never committed).
/Lean/
storage/
results/

# Scoreboard rows (live data) — published from CI, not from local
scoreboard/
*.jsonl
!tests/**/*.jsonl

# Logs
*.log
logs/

# M8 UI — dev-mode local state (production state lives at DIPDIVER_UI_DATA_ROOT
# on the VM and is never committed).
db/
config/ui_config.yaml
rendered/

